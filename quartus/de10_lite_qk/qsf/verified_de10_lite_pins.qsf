# Verified DE10-Lite pin assignments for the qk/de10_lite_qk project.
#
# Source: Terasic DE10-Lite SystemCD Golden_Top QSF
#   /home/monad/develop/ai_accel/DE10-Lite_SystemCD/Demonstrations/Golden_Top/DE10_LITE_Golden_Top.qsf
#
# This file intentionally contains only pins used by De10LiteTop:
#   CLOCK_50, SW[9:0], KEY[1:0], LEDR[9:0], HEX0..HEX5[6:0].
#
# No pin locations are guessed here. CLOCK_50 maps to the official
# MAX10_CLK1_50 board clock assignment from the source QSF.
# HEX decimal-point pins [7] and unused board peripherals are excluded.

set_instance_assignment -name IO_STANDARD "3.3-V LVTTL" -to CLOCK_50
set_location_assignment PIN_P11 -to CLOCK_50
set_instance_assignment -name IO_STANDARD "3.3-V LVTTL" -to HEX0[0]
